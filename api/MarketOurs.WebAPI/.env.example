# ========================================
# JWT Configuration (JWT 认证配置)
# ========================================
JWT_ACCESS_TOKEN_EXPIRY_MINUTES=20
JWT_REFRESH_TOKEN_EXPIRY_HOURS=72
JWT_RSA_PRIVATE_KEY_PATH=./keys/rsa_private.pem
JWT_RSA_PUBLIC_KEY_PATH=./keys/rsa_public.pem
JWT_ISSUER=MarketOurs
JWT_AUDIENCE=MarketOurs
JWT_KEY_ROTATION_DAYS=90

# ========================================
# Email Configuration (邮件服务配置)
# ========================================
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL=

# ========================================
# OAuth2 Authentication (第三方登录配置)
# ========================================
GITHUB_CLIENTID=default
GITHUB_CLIENTSECRET=default

GOOGLE_CLIENTID=default
GOOGLE_CLIENTSECRET=default

WEIXIN_CLIENTID=default
WEIXIN_CLIENTSECRET=default

# ========================================
# Database & Cache (数据库与缓存配置)
# ========================================
# 留空将默认使用 SQLite (Data.db)
# SQL=Host=localhost;Database=marketours;Username=postgres;Password=postgres

# 无配置则不使用 Redis 分布式缓存
REDIS=

# ========================================
# Admin User Initialization (初始管理员配置)
# ========================================
# 格式: 用户名,密码 (留空默认创建 root 账号，密码 123456)
USER=